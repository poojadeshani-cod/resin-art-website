<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= product.name %> – shreyadeshani.art</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="shop-body">

<header class="top-nav border-bottom">
  <div class="container d-flex justify-content-between align-items-center py-3">
    <a href="/" class="nav-link-main back-home-link">Home</a>
    <nav class="d-flex flex-wrap align-items-center gap-3">
      <div class="dropdown">
        <button class="btn nav-link-main nav-dropdown-toggle menu-toggle-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Menu">
          ☰
        </button>
        <ul class="dropdown-menu nav-dropdown-menu">
          <li><a class="dropdown-item" href="/category/resin-jewelry">Resin Jewellery</a></li>
          <li><a class="dropdown-item" href="/category/resin-preservation">Resin Preservation</a></li>
          <li><a class="dropdown-item" href="/category/interior">Interior</a></li>
          <li><a class="dropdown-item" href="/category/scented-candles">Scented Candles</a></li>
          <li><a class="dropdown-item" href="/workshops">Workshops</a></li>
        </ul>
      </div>
      <a href="/cart" class="cart-link d-flex align-items-center gap-2" aria-label="Cart">
        <span class="cart-icon" aria-hidden="true">🛒</span>
        <span class="badge bg-dark" id="cart-count-badge">0</span>
      </a>
    </nav>
  </div>
</header>


<section class="brand-section text-center mt-4">
  <div class="container">
    <h1 class="brand-name">shreyadeshani.art</h1>
    <p class="brand-tagline">NATURE INSPIRED</p>
  </div>
</section>


<section class="products-section py-4">
  <div class="container">

    <div class="row g-4 align-items-start">

      <div class="col-md-6">
        <% if (product.imageUrl) { %>
        <img
          src="<%= product.imageUrl %>"
          alt="<%= product.name %>"
          class="img-fluid rounded-4 shadow-sm">
        <% } %>
      </div>


      <div class="col-md-6">

        <h2 class="section-title mb-2"><%= product.name %></h2>

        <% if (product.categorySlug && categoryLabel) { %>
        <p class="small text-muted mb-2">
          <a href="/category/<%= product.categorySlug %>" class="text-muted text-decoration-none">
            <%= categoryLabel %>
          </a>
        </p>
        <% } %>

        <p class="fw-semibold fs-5 mb-3">
          ₹<%= product.price.toFixed(2) %>
        </p>

        <% if (product.description) { %>
        <p class="mb-3">
          <%= product.description %>
        </p>
        <% } %>


        <!-- Add to Cart Button -->
        <div
          class="btn btn-add-to-cart px-4"
          id="single-add-to-cart-btn"
          data-product='<%- JSON.stringify({
            _id: product._id,
            name: product.name,
            price: product.price,
            imageUrl: product.imageUrl,
            categoryName: categoryLabel || ""
          }) %>'
        >
          Add to Cart
        </div>


      </div>

    </div>

  </div>
</section>


<script>
window.WHATSAPP_NUMBER = "<%= whatsappNumber %>";
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/shop.js"></script>

</body>
</html>