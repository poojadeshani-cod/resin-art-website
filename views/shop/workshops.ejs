<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Workshops – shreyadeshani.art</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="shop-body">
  <header class="top-nav border-bottom">
    <div class="container d-flex justify-content-between align-items-center py-3">
      <a href="/" class="nav-link-main back-home-link">Home</a>
      <nav class="d-flex flex-wrap align-items-center gap-3">
        <div class="dropdown">
          <button class="btn nav-link-main nav-dropdown-toggle menu-toggle-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Menu">
            ☰
          </button>
          <ul class="dropdown-menu nav-dropdown-menu">
            <li><a class="dropdown-item" href="/category/resin-jewelry">Resin Jewellery</a></li>
            <li><a class="dropdown-item" href="/category/resin-preservation">Resin Preservation</a></li>
            <li><a class="dropdown-item" href="/category/interior">Interior</a></li>
            <li><a class="dropdown-item" href="/category/scented-candles">Scented Candles</a></li>
            <li><a class="dropdown-item active" href="/workshops">Workshops</a></li>
          </ul>
        </div>
        <a href="/cart" class="cart-link d-flex align-items-center gap-2" aria-label="Cart">
          <span class="cart-icon" aria-hidden="true">🛒</span>
          <span class="badge bg-dark" id="cart-count-badge">0</span>
        </a>
      </nav>
    </div>
  </header>

  <section class="brand-section text-center mt-4">
    <div class="container">
      <h1 class="brand-name">shreyadeshani.art</h1>
      <p class="brand-tagline">NATURE INSPIRED</p>
    </div>
  </section>

  <main class="py-4 py-md-5 workshops-page-main">
    <div class="container">
      <h2 class="section-title text-center mb-2">Workshops</h2>
      <p class="text-muted text-center small mb-4 mx-auto workshop-section-lede">
        Book your spot — we’ll confirm on WhatsApp.
      </p>

      <% if (!workshops || !workshops.length) { %>
        <div class="workshops-empty-state text-center py-5 px-3">
          <p class="workshops-empty-state__title mb-3">No upcoming workshops</p>
          <p class="workshops-empty-state__sub mb-4">
            Check back later or contact us for private sessions
          </p>
          <a href="/" class="text-muted small text-decoration-none">← Back to home</a>
        </div>
      <% } else { %>
        <div class="row g-4 justify-content-center workshop-grid-row">
          <% workshops.forEach(function (w, index) { %>
            <%- include('../partials/workshop-grid-card', {
              w: w,
              index: index,
              whatsappUrl: whatsappUrls[w._id.toString()]
            }) %>
          <% }) %>
        </div>
        <p class="text-center mt-4 mb-0"><a href="/" class="text-muted small text-decoration-none">← Back to home</a></p>
      <% } %>
    </div>
  </main>

  <script>window.WHATSAPP_NUMBER = "<%= whatsappNumber %>";</script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/shop.js"></script>
</body>
</html>
