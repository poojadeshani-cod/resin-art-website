<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cart – shreyadeshani.art</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

</head>


<body class="shop-body">

<!-- NAVBAR -->
<header class="top-nav border-bottom">
<div class="container d-flex justify-content-between align-items-center py-3">
<a href="/" class="nav-link-main back-home-link">Home</a>
<nav class="d-flex flex-wrap align-items-center gap-3">
<div class="dropdown">
<button class="btn nav-link-main nav-dropdown-toggle menu-toggle-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Menu">
☰
</button>
<ul class="dropdown-menu nav-dropdown-menu">
<li><a class="dropdown-item" href="/category/resin-jewelry">Resin Jewellery</a></li>
<li><a class="dropdown-item" href="/category/resin-preservation">Resin Preservation</a></li>
<li><a class="dropdown-item" href="/category/interior">Interior</a></li>
<li><a class="dropdown-item" href="/category/scented-candles">Scented Candles</a></li>
<li><a class="dropdown-item" href="/workshops">Workshops</a></li>
</ul>
</div>
<a href="/cart" class="cart-link d-flex align-items-center gap-2" aria-label="Cart">
<span class="cart-icon" aria-hidden="true">🛒</span>
<span class="badge bg-dark" id="cart-count-badge">0</span>
</a>

</nav>
</div>
</header>


<!-- TITLE -->
<section class="brand-section text-center mt-4">
<div class="container">
<h1 class="brand-name">Your Cart</h1>
<p class="brand-tagline">NATURE INSPIRED</p>
</div>
</section>


<!-- CART -->
<section class="cart-section py-5">
<div class="container">

<div class="d-flex justify-content-between align-items-center mb-4">
<h3 class="section-title">Cart</h3>

<button
id="clear-cart-btn"
class="btn btn-outline-danger btn-sm rounded-pill px-3">
Clear Cart
</button>

</div>


<div id="cart-items" class="mb-4"></div>


<div class="row mt-4">

<div class="col-md-8">

<label class="form-label">
Customization note (optional)
</label>

<textarea
id="order-note"
class="form-control"
rows="3"
placeholder="Example: pastel flowers with gold flakes">
</textarea>

</div>


<div class="col-md-4">

<div class="card border-0 shadow-sm cart-summary">

<div class="card-body">

<div class="d-flex justify-content-between mb-3">
<span>Total</span>
<strong>₹<span id="cart-total">0.00</span></strong>
</div>


<div class="mb-2">
<input
type="text"
id="customer-name"
class="form-control"
placeholder="Your Name">
</div>

<div class="mb-2">
<input
type="text"
id="customer-phone"
class="form-control"
placeholder="Phone">
</div>

<div class="mb-3">
<textarea
id="customer-address"
class="form-control"
rows="2"
placeholder="Address"></textarea>
</div>


<button
id="whatsapp-checkout-btn"
class="btn btn-dark w-100 rounded-pill">

Order on WhatsApp

</button>

</div>

</div>

</div>

</div>

</div>
</section>


<script>
window.WHATSAPP_NUMBER = "<%= whatsappNumber %>";
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/shop.js"></script>

</body>
</html>