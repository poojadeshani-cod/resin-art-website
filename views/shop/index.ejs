<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>shreyadeshani.art – Nature Inspired</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="shop-body">
  <!-- Top navigation -->
  <header class="top-nav border-bottom">
    <div class="container d-flex justify-content-center justify-content-md-between align-items-center py-3">
      <nav class="nav nav-main gap-4">
        <a class="nav-link-main active" href="#shop">SHOP</a>
        <a class="nav-link-main" href="#collections">COLLECTIONS</a>
        <a class="nav-link-main" href="#about">ABOUT</a>
        <a class="nav-link-main" href="#contact">CONTACT</a>
      </nav>

      <a href="#cart-section" class="cart-link d-none d-md-flex align-items-center gap-2" aria-label="Cart">
        <span class="cart-icon" aria-hidden="true">🛒</span>
        <span class="badge bg-dark" id="cart-count-badge">0</span>
      </a>
    </div>
  </header>

  <!-- Brand / Logo -->
  <section class="brand-section text-center mt-4">
    <div class="container">
      <h1 class="brand-name">shreyadeshani.art</h1>
      <p class="brand-tagline">NATURE INSPIRED</p>
    </div>
  </section>

  <!-- Hero section -->
  <section class="hero-section py-4 py-md-5" id="shop">
    <div class="container">
      <div class="row align-items-center gy-4">
        <div class="col-md-5 d-flex justify-content-center">
          <div class="hero-image-wrapper">
            <!-- You can replace this src with your own portrait -->
            <img
              src="https://images.pexels.com/photos/614810/pexels-photo-614810.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Artist portrait"
              class="hero-image"
            >
          </div>
        </div>
        <div class="col-md-7">
          <p class="hero-lede">
            Handmade resin creations that preserve memories and elevate spaces. From flower preservation to custom interior pieces and resin décor, each artwork is crafted with care, detail, and emotion.
          </p>
          <button class="btn btn-outline-dark hero-cta" onclick="document.getElementById('products-section').scrollIntoView({behavior:'smooth'});">
            EXPLORE DESIGNS
          </button>
        </div>
      </div>

      <!-- Category “chips” -->
      <div class="category-pills-wrapper mt-4">
        <div id="category-list" class="category-pills d-flex flex-wrap justify-content-center gap-3">
          <!-- Filled dynamically by JS -->
        </div>
      </div>
    </div>
  </section>

  <!-- Products section -->
  <section class="products-section py-4" id="products-section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title" id="product-section-title">All Products</h2>
        <span class="text-muted small" id="product-count-label"></span>
      </div>
      <div id="product-list" class="row g-4">
        <!-- Product cards via JS -->
      </div>
    </div>
  </section>

  <!-- Cart section -->
  <section class="cart-section py-5" id="cart-section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="section-title mb-0">Cart</h3>
        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" id="clear-cart-btn">Clear Cart</button>
      </div>

      <div id="cart-items" class="mb-4"></div>

      <div class="row gy-3">
        <div class="col-md-8">
          <label class="form-label">Order-wide customization note (optional)</label>
          <textarea
            id="order-note"
            class="form-control"
            rows="3"
            placeholder="Example: Please make the pendant with pastel blue flowers and gold flakes..."
          ></textarea>
        </div>
        <div class="col-md-4">
          <div class="cart-summary card border-0 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span>Total</span>
                <strong>₹<span id="cart-total">0.00</span></strong>
              </div>

              <div class="mb-2">
                <label class="form-label small mb-1">Your Name</label>
                <input type="text" id="customer-name" class="form-control" placeholder="Your full name">
              </div>
              <div class="mb-2">
                <label class="form-label small mb-1">Phone</label>
                <input type="text" id="customer-phone" class="form-control" placeholder="Your phone number">
              </div>
              <div class="mb-3">
                <label class="form-label small mb-1">Address</label>
                <textarea id="customer-address" class="form-control" rows="2" placeholder="Delivery address"></textarea>
              </div>

              <button class="btn btn-dark w-100 rounded-pill" id="whatsapp-checkout-btn">
                Order on WhatsApp
              </button>
              <small class="text-muted d-block mt-2">
                WhatsApp will open with your full order summary.
              </small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Simple placeholder sections for nav anchors -->
  <section id="collections" class="placeholder-section py-4"></section>
  <section id="about" class="placeholder-section py-4"></section>
  <section id="contact" class="placeholder-section py-4"></section>

  <script>
    window.WHATSAPP_NUMBER = "<%= whatsappNumber %>";
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/shop.js"></script>
</body>
</html>