<%- include('../partials/admin-header', { title: 'Products' }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Products</h3>
  <a href="/admin/products/new" class="btn btn-primary btn-sm">Add Product</a>
</div>

<table class="table table-striped align-middle">
  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Category</th>
      <th>Price</th>
      <th style="width:160px;">Actions</th>
    </tr>
  </thead>
  <tbody>
  <% products.forEach(p => { %>
    <tr>
      <td>
        <% if (p.imageUrl) { %>
          <img src="<%= p.imageUrl %>" alt="<%= p.name %>" style="width:60px; height:60px; object-fit:cover; border-radius:6px;">
        <% } else { %>
          <span class="text-muted">No image</span>
        <% } %>
      </td>
      <td><%= p.name %></td>
      <td><%= categoryLabelFromSlug(p.categorySlug) %></td>
      <td>₹<%= p.price.toFixed(2) %></td>
      <td>
        <a href="/admin/products/edit/<%= p._id %>" class="btn btn-sm btn-outline-secondary">Edit</a>
        <form action="/admin/products/delete/<%= p._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this product?');">
  
          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>
  </tbody>
</table>

<%- include('../partials/admin-footer') %>